    "¿Tiene sitio web?":             { "main": [[{ "node": "Extraer dominio y detectar industria","type": "main", "index": 0 }], []] },
    "Extraer dominio y detectar industria": { "main": [[{ "node": "¿Tiene email?",                "type": "main", "index": 0 }]] },
    "¿Tiene email?":                 { "main": [[{ "node": "OpenRouter — Generar Email Personalizado",  "type": "main", "index": 0 }], []] },
    "OpenRouter — Generar Email Personalizado": { "main": [[{ "node": "Esperar 3 min (anti-spam)",      "type": "main", "index": 0 }]] },
    "Esperar 3 min (anti-spam)":     { "main": [[{ "node": "Gmail — Enviar Email",                "type": "main", "index": 0 }]] },
    "Gmail — Enviar Email":          { "main": [[{ "node": "Registrar en Google Sheets",          "type": "main", "index": 0 }]] }
  },
  "active": false,
  "settings": { "executionOrder": "v1" }
}
